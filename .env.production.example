# ============================================================
# TherapyAssistance - Środowisko produkcyjne (mikr.us)
# Skopiuj do: .env.production
# NIGDY nie commituj .env.production do repozytorium!
# ============================================================

# ── Baza danych ───────────────────────────────────────────────
# PostgreSQL uruchomiony lokalnie na VPS
DATABASE_URL=postgresql+psycopg2://therapydb_user:ZMIEN_HASLO@localhost:5432/therapyassistance

# Alternatywnie, składowe zmienne (jeśli używasz deploy-mikrus.sh):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=therapyassistance
DB_USER=therapydb_user
DB_PASSWORD=ZMIEN_HASLO

# ── JWT ───────────────────────────────────────────────────────
# Wygeneruj silny klucz: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=ZMIEN_NA_SILNY_LOSOWY_KLUCZ
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── CORS ──────────────────────────────────────────────────────
# Tylko produkcyjne domeny (bez spacji!)
ALLOWED_ORIGINS=https://therapyassistance.io,https://www.therapyassistance.io

# ── Opcjonalne ────────────────────────────────────────────────
BACKEND_PORT=8000
